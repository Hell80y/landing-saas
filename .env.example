# Shared defaults for local development
NODE_ENV=development
PYTHON_ENV=development

# Infrastructure
POSTGRES_DB=landing_saas
POSTGRES_USER=landing
POSTGRES_PASSWORD=landing
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
DATABASE_URL=postgresql+psycopg://landing:landing@localhost:5432/landing_saas

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379/0

# Domain map
DASHBOARD_DOMAIN=app.localhost
API_DOMAIN=api.localhost
LANDING_DOMAIN=l.localhost
TRACKING_DOMAIN=t.localhost
ASSETS_DOMAIN=assets.localhost
